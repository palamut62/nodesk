{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nodesk",
  "version": "0.1.0",
  "identifier": "com.umuti.nodesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "nodesk",
        "url": "index.html#/widget",
        "width": 220,
        "height": 56,
        "minWidth": 200,
        "minHeight": 48,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "center": false,
        "x": 40,
        "y": 40
      },
      {
        "label": "editor",
        "title": "nodesk — note",
        "url": "index.html#/editor",
        "width": 640,
        "height": 560,
        "minWidth": 480,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

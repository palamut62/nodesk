{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nodesk",
  "version": "0.1.0",
  "identifier": "com.umuti.nodesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "nodesk",
        "url": "index.html",
        "width": 360,
        "height": 56,
        "minWidth": 200,
        "minHeight": 48,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false,
        "x": 40,
        "y": 40,
        "additionalBrowserArgs": "--use-fake-ui-for-media-stream --autoplay-policy=no-user-gesture-required --enable-features=MediaFoundationClearPlayback"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

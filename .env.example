# Notion entegrasyonu
# https://www.notion.so/profile/integrations → yeni integration oluştur → Internal Integration Secret
NOTION_API_KEY=secret_xxx
# Notların kaydedileceği database'in ID'si (URL'den al: notion.so/<workspace>/<DATABASE_ID>?v=...)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Başlık property adı (varsayılan: Name)
NOTION_TITLE_PROPERTY=Name

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=openai/gpt-4o-mini
